<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Las Chismosas — banda de ska, punk y reggae | Fechas y música</title>
<meta name="description" content="Las Chismosas — banda de ska / punk / reggae del under argentino. Próximas fechas en CABA, Avellaneda y La Plata, discos, videos y contrataciones.">
<meta name="robots" content="index, follow">
<meta name="theme-color" content="#17161a">
<link rel="canonical" href="{{canonicalUrl}}">

<meta property="og:type" content="website">
<meta property="og:site_name" content="Las Chismosas">
<meta property="og:title" content="Las Chismosas — banda de ska, punk y reggae">
<meta property="og:description" content="Banda de ska / punk / reggae del under argentino. Próximas fechas, música y contrataciones.">
<meta property="og:url" content="{{canonicalUrl}}">
<meta property="og:locale" content="es_AR">

<meta name="twitter:card" content="summary">
<meta name="twitter:title" content="Las Chismosas — banda de ska, punk y reggae">
<meta name="twitter:description" content="Banda de ska / punk / reggae del under argentino. Próximas fechas, música y contrataciones.">

<script type="application/ld+json">{{{jsonLd}}}</script>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Anton&family=Saira+Stencil+One&family=Oswald:wght@400;500;600;700&family=Patrick+Hand&display=swap" rel="stylesheet">
<script src="/image-slot.js" defer></script>
<style>
  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body { margin: 0; background: #17161a; }
  @keyframes lc-marquee { from { transform: translateX(0); } to { transform: translateX(-50%); } }
  ::selection { background: #e8472b; color: #f2efe6; }

  /* hover states — extracted from the design's style-hover attributes */
  a, button { transition: background-color .12s, color .12s, transform .12s, box-shadow .12s, border-color .12s; }
  .lc-nav-link:hover { color: #17161a !important; background: #e8472b !important; }
  .lc-nav-cta:hover { color: #f2efe6 !important; background: #e8472b !important; }
  .lc-btn-primary:hover { background: #e8472b !important; color: #17161a !important; box-shadow: 5px 5px 0 #17161a !important; transform: translate(-2px,-2px); }
  .lc-btn-secondary:hover { background: #f4c20d !important; }
  .lc-pill-spotify:hover { border-color: #1DB954 !important; background: #1DB954 !important; color: #17161a !important; }
  .lc-pill-youtube:hover { border-color: #ff3b30 !important; background: #ff3b30 !important; color: #17161a !important; }
  .lc-pill-bandcamp:hover { border-color: #f4c20d !important; background: #f4c20d !important; color: #17161a !important; }
  .lc-pill-social:hover { border-color: #e8472b !important; background: #e8472b !important; color: #17161a !important; }
  .lc-show-btn:hover { background: #e8472b !important; color: #17161a !important; }
  .lc-news-btn:hover { background: #f4c20d !important; }

  /* mobile reflow */
  @media (max-width: 760px) {
    .lc-hero-grid { grid-template-columns: 1fr !important; }
    .lc-music-grid { grid-template-columns: 1fr !important; }
    .lc-contact-grid { grid-template-columns: 1fr !important; }
    .lc-show-row { grid-template-columns: 80px 1fr !important; }
    .lc-show-row .lc-show-cta { grid-column: 1 / -1; justify-self: start; }
  }
</style>
</head>
<body>

<div style="font-family:'Oswald',sans-serif;color:#171614;background:#f2efe6;background-image:radial-gradient(rgba(23,22,20,.14) 1.05px, transparent 1.15px);background-size:6px 6px;overflow-x:hidden;">

  <!-- ================= NAV ================= -->
  <header style="position:sticky;top:0;z-index:60;background:#17161a;color:#f2efe6;border-bottom:3px solid #000;">
    <nav aria-label="Navegación principal" style="max-width:1180px;margin:0 auto;padding:13px 22px;display:flex;align-items:center;gap:18px;flex-wrap:wrap;">
      <a href="#top" style="display:flex;align-items:center;gap:9px;text-decoration:none;color:#f2efe6;">
        <span style="width:26px;height:26px;background:repeating-conic-gradient(#f2efe6 0% 25%, #17161a 0% 50%) 0 0 / 13px 13px;border:1.5px solid #f2efe6;display:inline-block;"></span>
        <span style="font-family:'Anton',sans-serif;letter-spacing:1.5px;font-size:19px;">LAS CHISMOSAS</span>
      </a>
      <div style="margin-left:auto;display:flex;gap:4px;flex-wrap:wrap;font-family:'Oswald',sans-serif;font-weight:600;font-size:14px;letter-spacing:1px;text-transform:uppercase;">
        <a href="#shows" class="lc-nav-link" style="text-decoration:none;color:#f2efe6;padding:7px 12px;">Shows</a>
        <a href="#musica" class="lc-nav-link" style="text-decoration:none;color:#f2efe6;padding:7px 12px;">Música</a>
        <a href="#banda" class="lc-nav-link" style="text-decoration:none;color:#f2efe6;padding:7px 12px;">La banda</a>
        <a href="#contacto" class="lc-nav-cta" style="text-decoration:none;color:#17161a;background:#f4c20d;padding:7px 14px;">Contacto</a>
      </div>
    </nav>
  </header>

  <main>
  <!-- ================= HERO ================= -->
  <section id="top" style="position:relative;border-bottom:4px solid #17161a;overflow:hidden;">
    <div class="lc-hero-grid" style="max-width:1180px;margin:0 auto;padding:64px 22px 70px;display:grid;grid-template-columns:1.25fr .9fr;gap:40px;align-items:center;">
      <div>
        <div style="display:inline-flex;align-items:center;gap:8px;font-family:'Oswald',sans-serif;font-weight:700;font-size:13px;letter-spacing:3px;text-transform:uppercase;background:#17161a;color:#f2efe6;padding:6px 13px;margin-bottom:22px;">
          <span style="width:8px;height:8px;background:#e8472b;border-radius:50%;display:inline-block;"></span>
          Under argentino · ska · punk · reggae
        </div>
        <h1 style="margin:0;font-family:'Anton',sans-serif;line-height:.84;letter-spacing:1px;">
          <span style="display:block;font-size:clamp(48px,8.6vw,112px);color:#f2efe6;-webkit-text-stroke:3px #17161a;">LAS</span>
          <span style="display:block;font-size:clamp(43px,7.9vw,103px);color:#17161a;">CHISMO<span style="color:#e8472b;">SAS</span></span>
        </h1>
        <div style="margin-top:22px;max-width:430px;font-family:'Patrick Hand',cursive;font-size:21px;color:#3a352e;line-height:1.3;">
          Seis personas que no deberían estar arriba de un escenario — pero ahí están, dando todo.
        </div>
        <div style="display:flex;gap:14px;margin-top:30px;flex-wrap:wrap;">
          <a href="#shows" class="lc-btn-primary" style="text-decoration:none;display:inline-flex;align-items:center;gap:9px;background:#17161a;color:#f2efe6;font-family:'Oswald',sans-serif;font-weight:700;font-size:16px;letter-spacing:1px;text-transform:uppercase;padding:15px 26px;border:2px solid #17161a;box-shadow:5px 5px 0 #e8472b;">Próximo show →</a>
          <a href="#musica" class="lc-btn-secondary" style="text-decoration:none;display:inline-flex;align-items:center;gap:9px;background:transparent;color:#17161a;font-family:'Oswald',sans-serif;font-weight:700;font-size:16px;letter-spacing:1px;text-transform:uppercase;padding:15px 26px;border:2px solid #17161a;">▶ Escuchar</a>
        </div>
      </div>
      <div style="position:relative;display:flex;justify-content:center;">
        <div style="position:relative;transform:rotate(3deg);background:#fff;padding:12px 12px 46px;border:1px solid #d8d2c4;box-shadow:9px 12px 0 rgba(23,22,20,.16);">
          <div style="position:absolute;top:-13px;left:50%;transform:translateX(-50%) rotate(-4deg);width:120px;height:26px;background:rgba(244,194,13,.72);border:1px dashed rgba(23,22,20,.4);"></div>
          <image-slot id="hero-photo" style="width:300px;height:340px;display:block;" shape="rect" placeholder="Arrastrá una foto de la banda"></image-slot>
          <div style="position:absolute;left:0;right:0;bottom:12px;text-align:center;font-family:'Patrick Hand',cursive;font-size:18px;color:#3a352e;">la banda, ayer, sin ensayar</div>
        </div>
      </div>
    </div>
    <div style="height:24px;background:repeating-conic-gradient(#17161a 0% 25%, #f2efe6 0% 50%) 0 0 / 24px 24px;border-top:3px solid #17161a;"></div>
  </section>

  <!-- ================= MARQUEE ================= -->
  <div aria-hidden="true" style="background:#e8472b;color:#17161a;border-bottom:4px solid #17161a;overflow:hidden;padding:11px 0;">
    <div style="display:flex;width:max-content;animation:lc-marquee 22s linear infinite;font-family:'Anton',sans-serif;font-size:21px;letter-spacing:2px;">
      <span style="padding:0 24px;">★ DISCO NUEVO YA EN LA CALLE ★ GIRA 2026 ★ SUENA FEO PERO CON ONDA ★ ENTRADAS A LA VENTA ★ DISCO NUEVO YA EN LA CALLE ★ GIRA 2026 ★ SUENA FEO PERO CON ONDA ★ ENTRADAS A LA VENTA&nbsp;★&nbsp;</span>
      <span style="padding:0 24px;">★ DISCO NUEVO YA EN LA CALLE ★ GIRA 2026 ★ SUENA FEO PERO CON ONDA ★ ENTRADAS A LA VENTA ★ DISCO NUEVO YA EN LA CALLE ★ GIRA 2026 ★ SUENA FEO PERO CON ONDA ★ ENTRADAS A LA VENTA&nbsp;★&nbsp;</span>
    </div>
  </div>

  <!-- ================= SHOWS ================= -->
  <section id="shows" aria-labelledby="shows-title" style="max-width:920px;margin:0 auto;padding:74px 22px 30px;">
    <div style="display:flex;align-items:baseline;gap:16px;margin-bottom:8px;flex-wrap:wrap;">
      <h2 id="shows-title" style="margin:0;font-family:'Saira Stencil One',sans-serif;font-size:clamp(34px,6vw,58px);color:#17161a;">PRÓXIMAS FECHAS</h2>
      <span style="font-family:'Patrick Hand',cursive;font-size:20px;color:#e8472b;transform:rotate(-3deg);display:inline-block;">¡veníte!</span>
    </div>
    <div style="height:3px;background:#17161a;margin-bottom:26px;"></div>

    <div style="display:flex;flex-direction:column;gap:16px;">
      {{#each shows}}
        <article class="lc-show-row" style="position:relative;display:grid;grid-template-columns:104px 1fr auto;gap:20px;align-items:center;background:#fff;border:2px solid #17161a;padding:16px 18px;box-shadow:5px 5px 0 rgba(23,22,20,.14);">
          <time datetime="{{isoDate}}" style="display:block;text-align:center;border-right:2px dashed #cfcabb;padding-right:14px;">
            <span style="display:block;font-family:'Anton',sans-serif;font-size:42px;line-height:.9;color:#17161a;">{{d}}</span>
            <span style="display:block;font-family:'Oswald',sans-serif;font-weight:700;font-size:15px;letter-spacing:2px;color:#e8472b;">{{m}}</span>
          </time>
          <div>
            <h3 style="margin:0;font-family:'Oswald',sans-serif;font-weight:700;font-size:21px;letter-spacing:.5px;text-transform:uppercase;">{{venue}}</h3>
            <div style="font-family:'Oswald',sans-serif;font-size:15px;color:#6b6459;">{{city}} · {{note}}</div>
          </div>
          {{#if isEntradas}}
            <a href="#contacto" class="lc-show-btn lc-show-cta" style="text-decoration:none;background:#17161a;color:#f2efe6;font-family:'Oswald',sans-serif;font-weight:700;font-size:15px;letter-spacing:1px;text-transform:uppercase;padding:12px 20px;white-space:nowrap;">Entradas</a>
          {{/if}}
          {{#if isAgotado}}
            <span class="lc-show-cta" style="font-family:'Saira Stencil One',sans-serif;font-size:20px;color:#e8472b;border:3px solid #e8472b;padding:6px 14px;transform:rotate(-7deg);display:inline-block;white-space:nowrap;">AGOTADO</span>
          {{/if}}
        </article>
      {{/each}}
    </div>
    <div style="font-family:'Patrick Hand',cursive;font-size:18px;color:#6b6459;margin-top:18px;">¿Querés que toquemos en tu ciudad / cumpleaños / casamiento? Escribinos abajo.</div>
  </section>

  <!-- ================= MUSICA ================= -->
  <section id="musica" aria-labelledby="musica-title" style="background:#17161a;color:#f2efe6;border-top:4px solid #17161a;border-bottom:4px solid #17161a;margin-top:50px;">
    <div style="max-width:1100px;margin:0 auto;padding:74px 22px;">
      <div style="display:flex;align-items:baseline;gap:16px;margin-bottom:8px;flex-wrap:wrap;">
        <h2 id="musica-title" style="margin:0;font-family:'Saira Stencil One',sans-serif;font-size:clamp(34px,6vw,58px);color:#f2efe6;">ESCUCHÁ EL QUILOMBO</h2>
      </div>
      <div style="height:3px;background:#e8472b;margin-bottom:30px;"></div>

      <div class="lc-music-grid" style="display:grid;grid-template-columns:minmax(0,1.4fr) minmax(0,1fr);gap:26px;align-items:start;">
        <div>
          <image-slot id="video-feat" style="width:100%;aspect-ratio:16/9;display:block;border:2px solid #f2efe6;" shape="rect" placeholder="Pegá el video destacado (YouTube)"></image-slot>
          <div style="display:flex;gap:10px;margin-top:16px;flex-wrap:wrap;">
            <span class="lc-pill-spotify" style="display:inline-flex;align-items:center;gap:8px;font-family:'Oswald',sans-serif;font-weight:700;font-size:14px;letter-spacing:1px;text-transform:uppercase;border:2px solid #f2efe6;padding:10px 16px;cursor:pointer;">● Spotify</span>
            <span class="lc-pill-youtube" style="display:inline-flex;align-items:center;gap:8px;font-family:'Oswald',sans-serif;font-weight:700;font-size:14px;letter-spacing:1px;text-transform:uppercase;border:2px solid #f2efe6;padding:10px 16px;cursor:pointer;">▶ YouTube</span>
            <span class="lc-pill-bandcamp" style="display:inline-flex;align-items:center;gap:8px;font-family:'Oswald',sans-serif;font-weight:700;font-size:14px;letter-spacing:1px;text-transform:uppercase;border:2px solid #f2efe6;padding:10px 16px;cursor:pointer;">◆ Bandcamp</span>
          </div>
        </div>
        <div style="display:flex;flex-direction:column;gap:16px;">
          <div style="display:flex;gap:14px;align-items:center;">
            <image-slot id="cover-1" style="width:96px;height:96px;display:block;border:2px solid #f2efe6;flex:none;" shape="rect" placeholder="tapa"></image-slot>
            <div style="flex:1;min-width:0;">
              <div style="font-family:'Oswald',sans-serif;font-weight:700;font-size:17px;line-height:1.15;text-transform:uppercase;">Sale Quemado</div>
              <div style="font-family:'Oswald',sans-serif;font-size:14px;color:#a9a298;">LP · 2026 · 11 temas</div>
            </div>
          </div>
          <div style="display:flex;gap:14px;align-items:center;">
            <image-slot id="cover-2" style="width:96px;height:96px;display:block;border:2px solid #f2efe6;flex:none;" shape="rect" placeholder="tapa"></image-slot>
            <div style="flex:1;min-width:0;">
              <div style="font-family:'Oswald',sans-serif;font-weight:700;font-size:17px;line-height:1.15;text-transform:uppercase;">Chimento</div>
              <div style="font-family:'Oswald',sans-serif;font-size:14px;color:#a9a298;">EP · 2024 · 5 temas</div>
            </div>
          </div>
          <div style="display:flex;gap:14px;align-items:center;">
            <image-slot id="cover-3" style="width:96px;height:96px;display:block;border:2px solid #f2efe6;flex:none;" shape="rect" placeholder="tapa"></image-slot>
            <div style="flex:1;min-width:0;">
              <div style="font-family:'Oswald',sans-serif;font-weight:700;font-size:17px;line-height:1.15;text-transform:uppercase;">Demo del Garage</div>
              <div style="font-family:'Oswald',sans-serif;font-size:14px;color:#a9a298;">Single · 2023</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================= BANDA ================= -->
  <section id="banda" aria-labelledby="banda-title" style="max-width:1020px;margin:0 auto;padding:74px 22px 40px;">
    <div style="display:flex;align-items:baseline;gap:16px;margin-bottom:8px;flex-wrap:wrap;">
      <h2 id="banda-title" style="margin:0;font-family:'Saira Stencil One',sans-serif;font-size:clamp(34px,6vw,58px);color:#17161a;">LA BANDA</h2>
      <span style="font-family:'Patrick Hand',cursive;font-size:20px;color:#6b6459;transform:rotate(-2deg);display:inline-block;">seis, contando los que faltan</span>
    </div>
    <div style="height:3px;background:#17161a;margin-bottom:34px;"></div>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(258px,1fr));gap:30px 26px;">
      {{#each band}}
        <div style="text-align:center;">
          <div style="position:relative;display:inline-block;background:#fff;border:2px solid #17161a;padding:10px 10px 14px;box-shadow:6px 6px 0 rgba(23,22,20,.14);transform:rotate({{tilt}});">
            <span style="position:absolute;top:-11px;left:50%;transform:translateX(-50%);width:17px;height:17px;border-radius:50%;background:#e8472b;border:2px solid #17161a;box-shadow:0 3px 3px rgba(0,0,0,.3);"></span>
            <image-slot id="band-{{slot}}" style="width:200px;height:210px;display:block;" shape="rect" placeholder="{{role}}"></image-slot>
          </div>
          <div style="font-family:'Anton',sans-serif;font-size:26px;letter-spacing:1px;margin-top:14px;">{{name}}</div>
          <div style="font-family:'Oswald',sans-serif;font-weight:700;font-size:14px;letter-spacing:2px;text-transform:uppercase;color:#e8472b;">{{role}}</div>
          <div style="font-family:'Patrick Hand',cursive;font-size:17px;color:#6b6459;margin-top:4px;">&ldquo;{{line}}&rdquo;</div>
        </div>
      {{/each}}
    </div>
  </section>
  </main>

  <!-- ================= CONTACTO / FOOTER ================= -->
  <footer id="contacto" style="background:#17161a;color:#f2efe6;border-top:4px solid #17161a;">
    <div style="height:24px;background:repeating-conic-gradient(#e8472b 0% 25%, #17161a 0% 50%) 0 0 / 24px 24px;"></div>
    <div class="lc-contact-grid" style="max-width:1020px;margin:0 auto;padding:64px 22px 30px;display:grid;grid-template-columns:1.1fr 1fr;gap:46px;align-items:start;">
      <div>
        <h2 style="margin:0 0 10px;font-family:'Saira Stencil One',sans-serif;font-size:clamp(30px,5vw,48px);">SEGUINOS / ESCRIBINOS</h2>
        <div style="font-family:'Patrick Hand',cursive;font-size:19px;color:#cbc4b9;max-width:380px;margin-bottom:26px;">Contrataciones, fechas, o para mandarnos un chisme: caemos a cualquier lado con tal de tocar.</div>
        <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:22px;">
          <span class="lc-pill-social" style="font-family:'Oswald',sans-serif;font-weight:700;font-size:14px;letter-spacing:1px;text-transform:uppercase;border:2px solid #f2efe6;padding:10px 16px;cursor:pointer;">Instagram</span>
          <span class="lc-pill-social" style="font-family:'Oswald',sans-serif;font-weight:700;font-size:14px;letter-spacing:1px;text-transform:uppercase;border:2px solid #f2efe6;padding:10px 16px;cursor:pointer;">YouTube</span>
          <span class="lc-pill-social" style="font-family:'Oswald',sans-serif;font-weight:700;font-size:14px;letter-spacing:1px;text-transform:uppercase;border:2px solid #f2efe6;padding:10px 16px;cursor:pointer;">TikTok</span>
          <span class="lc-pill-social" style="font-family:'Oswald',sans-serif;font-weight:700;font-size:14px;letter-spacing:1px;text-transform:uppercase;border:2px solid #f2efe6;padding:10px 16px;cursor:pointer;">Spotify</span>
        </div>
        <div style="font-family:'Oswald',sans-serif;font-size:16px;color:#cbc4b9;">contrataciones / DM → <span style="color:#f4c20d;font-weight:700;">@laschismosas</span></div>
      </div>
      <div style="background:#211f24;border:2px solid #3a3740;padding:24px;">
        <div style="font-family:'Oswald',sans-serif;font-weight:700;font-size:18px;letter-spacing:1px;text-transform:uppercase;margin-bottom:6px;">Lista de chismes</div>
        <div style="font-family:'Patrick Hand',cursive;font-size:17px;color:#cbc4b9;margin-bottom:16px;">Te avisamos shows y bardo nuevo. Cero spam (no sabemos cómo).</div>
        <form id="lc-newsletter-form" style="display:flex;gap:10px;flex-wrap:wrap;">
          <input id="lc-newsletter-email" type="email" required placeholder="tu mail" style="flex:1;min-width:150px;font-family:'Oswald',sans-serif;font-size:15px;padding:12px 14px;background:#f2efe6;color:#17161a;border:2px solid #17161a;outline:none;">
          <button type="submit" class="lc-news-btn" style="font-family:'Oswald',sans-serif;font-weight:700;font-size:15px;letter-spacing:1px;text-transform:uppercase;background:#e8472b;color:#17161a;border:2px solid #17161a;padding:12px 18px;cursor:pointer;">Anotarme</button>
        </form>
        <div id="lc-newsletter-msg" style="font-family:'Patrick Hand',cursive;font-size:16px;color:#f4c20d;margin-top:10px;min-height:20px;"></div>
      </div>
    </div>
    <div style="max-width:1020px;margin:0 auto;padding:18px 22px 40px;display:flex;justify-content:space-between;gap:16px;flex-wrap:wrap;border-top:1px solid #3a3740;margin-top:20px;">
      <span style="font-family:'Anton',sans-serif;font-size:18px;letter-spacing:1.5px;">LAS CHISMOSAS</span>
      <span style="font-family:'Oswald',sans-serif;font-size:13px;color:#8b857b;letter-spacing:.5px;">&copy; 2026 &middot; hecho a pulm&oacute;n en Buenos Aires &middot; suena feo pero con onda</span>
    </div>
  </footer>

</div>

<script src="/newsletter.js"></script>
</body>
</html>
